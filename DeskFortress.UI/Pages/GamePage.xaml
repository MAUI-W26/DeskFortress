<ContentPage
    x:Class="DeskFortress.UI.Pages.GamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#111111"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Score HUD -->
        <Grid
            Grid.Row="0"
            Padding="12,8"
            BackgroundColor="#22000000"
            ColumnDefinitions="*,Auto">
            <Label
                x:Name="ScoreLabel"
                Text="Score: 0"
                FontSize="16"
                TextColor="White"
                HorizontalOptions="Start" />

            <Button
                Grid.Column="1"
                x:Name="PauseButton"
                Text="Pause"
                FontSize="13"
                Padding="12,4"
                Clicked="OnPauseClicked" />
        </Grid>

        <!-- Game Viewport -->
        <Grid Grid.Row="1">

            <!-- World rendering (Core-driven) -->
            <Grid x:Name="Viewport" BackgroundColor="Black">
                <AbsoluteLayout x:Name="WorldRoot">
                    <Image x:Name="BackgroundImage"
                           Source="office_background.png"
                           Aspect="AspectFit"
                           InputTransparent="True" />
                    <AbsoluteLayout x:Name="WorldLayer"
                                    InputTransparent="True" />
                </AbsoluteLayout>
            </Grid>

                 <!-- Input overlay – PointerGestureRecognizer handles everything:
                     press within ball zone  → throw aim + release to throw
                     press outside ball zone → camera pan drag -->
            <Grid x:Name="InputOverlay"
                  BackgroundColor="#01000000">

                <!-- Single pointer recognizer: no TotalX/TotalY ambiguity, absolute coords -->
                <Grid.GestureRecognizers>
                    <PointerGestureRecognizer
                        PointerPressed="OnOverlayPointerPressed"
                        PointerMoved="OnOverlayPointerMoved"
                        PointerReleased="OnOverlayPointerReleased" />
                </Grid.GestureRecognizers>

                <!-- Throw trajectory preview arc (shown while aiming, hidden otherwise) -->
                <GraphicsView
                    x:Name="TrajectoryView"
                    IsVisible="False"
                    InputTransparent="True"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />

                                <Grid x:Name="PanSliderRoot"
                                            WidthRequest="168"
                                            HeightRequest="96"
                                            Margin="8,0,0,8"
                      HorizontalOptions="Start"
                      VerticalOptions="End">
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnPanSliderPanUpdated" />
                    </Grid.GestureRecognizers>

                                        <Border StrokeThickness="0"
                                                        WidthRequest="100"
                                                        HeightRequest="44"
                                                        HorizontalOptions="Start"
                                                        VerticalOptions="End"
                            StrokeShape="RoundRectangle 22"
                            BackgroundColor="#66171C26"
                            Padding="5">
                        <Grid>
                            <Label Text="◀        ▶"
                                   TextColor="#80FFFFFF"
                                   FontSize="11"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />

                            <Border x:Name="PanSliderThumb"
                                    WidthRequest="34"
                                    HeightRequest="34"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 17"
                                    BackgroundColor="#E6FFFFFF" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Large touch zone for throw on mobile/tablet. -->
                <Grid x:Name="ThrowTouchZone"
                      WidthRequest="220"
                      HeightRequest="170"
                      Margin="0,0,0,0"
                      HorizontalOptions="Center"
                      VerticalOptions="End"
                      BackgroundColor="#01000000">
                    <Grid.GestureRecognizers>
                        <PanGestureRecognizer PanUpdated="OnThrowBallPanUpdated" />
                    </Grid.GestureRecognizers>
                </Grid>

                <!-- Paperball stays fixed; drag direction controls aim, release throws. -->
                <Image x:Name="ThrowOriginBall"
                       Source="paperball01.png"
                       WidthRequest="56"
                       HeightRequest="56"
                       VerticalOptions="End"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"
                       InputTransparent="True" />

                <!-- Projectile sprite used only for the fake screen-space flight animation. -->
                <Image x:Name="ThrowFlyingBall"
                       Source="paperball01.png"
                       WidthRequest="56"
                       HeightRequest="56"
                       VerticalOptions="End"
                       HorizontalOptions="Center"
                       Margin="0,0,0,20"
                       IsVisible="False"
                       InputTransparent="True" />

            </Grid>

                <!-- Shared overlay used for pause and game-over states. -->
                <Grid x:Name="GameOverlay"
                  IsVisible="False"
                  BackgroundColor="#99000000"
                  InputTransparent="False"
                  Padding="20">

                <Border StrokeThickness="0"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="#F2171C26"
                    MaximumWidthRequest="420"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="18">
                    <VerticalStackLayout Spacing="12">
                    <Label x:Name="OverlayTitleLabel"
                           Text="Paused"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />

                    <Label x:Name="OverlayStatsLabel"
                           TextColor="#E6FFFFFF"
                           FontSize="14"
                           LineBreakMode="WordWrap" />

                    <Button x:Name="OverlayResumeButton"
                        Text="Resume"
                        Clicked="OnOverlayResumeClicked" />

                    <Button x:Name="OverlayRestartButton"
                        Text="Restart"
                        Clicked="OnOverlayRestartClicked" />

                    <Button x:Name="OverlayMenuButton"
                        Text="Main Menu"
                        Clicked="OnOverlayMainMenuClicked" />
                    </VerticalStackLayout>
                </Border>
                </Grid>

        </Grid>

    </Grid>
</ContentPage>