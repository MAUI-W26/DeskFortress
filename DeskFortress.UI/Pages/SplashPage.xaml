<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DeskFortress.UI.Pages.SplashPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="DeskFortress">

    <Grid Padding="24">
        <VerticalStackLayout
            Spacing="16"
            VerticalOptions="Center"
            HorizontalOptions="Center">

            <Image
                Source="hero.png."
                HeightRequest="180"
                WidthRequest="180" />

            <Label
                x:Name="StatusLabel"
                Text="Loading..."
                HorizontalTextAlignment="Center"
                FontSize="16" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>